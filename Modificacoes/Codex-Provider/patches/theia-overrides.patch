+    getPendingImagesForDisplay(): PendingImageDisplayEntry[] {
+        const editor = this.editorRef?.getControl();
+        const model = editor?.getModel();
+        if (!model) {
+            return [];
+        }
+
+        const scopeUri = this.getScopeUri();
+        const text = model.getValue();
+        const seen = new Set<string>();
+        const entries: PendingImageDisplayEntry[] = [];
+        const regex = new RegExp(IMAGE_CONTEXT_REF_REGEX.source, IMAGE_CONTEXT_REF_REGEX.flags);
+
+        for (const match of text.matchAll(regex)) {
+            const shortId = match[1];
+            if (seen.has(shortId)) {
+                continue;
+            }
+            seen.add(shortId);
+
+            const pendingData = this.pendingImageRegistry.get(scopeUri, shortId)
+                ?? this.pendingImageRegistry.getByShortId(shortId);
+            if (!pendingData) {
+                continue;
+            }
+
+            const imageVariable = pendingData.imageVariable;
+            entries.push({
+                shortId,
+                name: imageVariable.name ?? imageVariable.wsRelativePath?.split('/').pop() ?? shortId,
+                mimeType: imageVariable.mimeType,
+                data: imageVariable.data,
+                wsRelativePath: imageVariable.wsRelativePath,
+            });
+        }
+
+        return entries;
+    }
+
+    removePendingImage(shortId: string): void {
+        const editor = this.editorRef?.getControl();
+        const model = editor?.getModel();
+        if (editor && model) {
+            const escapedShortId = shortId.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
+            const nextValue = model.getValue()
+                .replace(new RegExp(`#imageContext:${escapedShortId}`, 'g'), '')
+                .replace(/[ \t]+\n/g, '\n')
+                .replace(/\n[ \t]+/g, '\n')
+                .replace(/[ \t]{2,}/g, ' ')
+                .trim();
+            editor.setValue(nextValue);
+        }
+
+        this.pendingImageDisposables.get(shortId)?.dispose();
+        this.pendingImageDisposables.delete(shortId);
+        this.refreshPendingImageDisplay();
+    }
