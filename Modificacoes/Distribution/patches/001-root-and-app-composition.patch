--- a/examples/playwright/src/theia-workspace.ts
+++ b/examples/playwright/src/theia-workspace.ts
@@ -84,7 +84,26 @@ export class TheiaWorkspace {
     }
 
     remove(): void {
-        fs.removeSync(this.workspacePath);
+        for (let attempt = 0; attempt < 5; attempt++) {
+            try {
+                fs.removeSync(this.workspacePath);
+                return;
+            } catch (error) {
+                const code = typeof error === 'object' && error && 'code' in error ? String(error.code) : '';
+                if (!['EBUSY', 'ENOTEMPTY', 'EPERM'].includes(code)) {
+                    throw error;
+                }
+                if (attempt === 4) {
+                    console.warn(`Could not remove temporary workspace ${this.workspacePath}: ${code}`);
+                    return;
+                }
+                this.sleep(250);
+            }
+        }
+    }
+
+    protected sleep(milliseconds: number): void {
+        Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, milliseconds);
     }
 
 }

