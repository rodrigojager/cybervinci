diff --git a/packages/getting-started/src/browser/style/index.css b/packages/getting-started/src/browser/style/index.css
index 8281c29..51b58d8 100644
--- a/packages/getting-started/src/browser/style/index.css
+++ b/packages/getting-started/src/browser/style/index.css
@@ -43,10 +43,14 @@ body {
   flex-direction: column;
   justify-content: space-between;
   height: 100%;
+  min-height: 0;
+  overflow-y: auto;
+  box-sizing: border-box;
 }
 
 .gs-content-container {
   padding: 20px;
+  flex: 0 0 auto;
 }
 
 .gs-content-container a {
@@ -58,6 +62,50 @@ body {
   font-weight: 600;
 }
 
+.cybervinci-welcome-hero {
+  display: grid;
+  grid-template-columns: minmax(220px, 260px) minmax(320px, 1fr);
+  align-items: center;
+  gap: 18px;
+  min-height: 280px;
+  overflow: hidden;
+}
+
+.cybervinci-welcome-copy {
+  justify-self: start;
+  text-align: left;
+}
+
+.cybervinci-welcome-copy h1 {
+  margin: 0 0 10px;
+  font-size: 34px;
+  line-height: 1.1;
+}
+
+.cybervinci-welcome-lead {
+  margin: 0 0 12px;
+  max-width: 720px;
+  font-size: var(--theia-ui-font-size3);
+  font-weight: 600;
+}
+
+.cybervinci-welcome-body {
+  margin: 0;
+  max-width: 780px;
+  color: var(--theia-descriptionForeground);
+  font-size: var(--theia-ui-font-size2);
+  line-height: 1.45;
+}
+
+.cybervinci-welcome-art {
+  align-self: stretch;
+  min-height: 260px;
+  background-image: url("./cybervinci-welcome.png");
+  background-repeat: no-repeat;
+  background-position: left bottom;
+  background-size: contain;
+}
+
 .gs-hr {
   background-color: var(--theia-contrastBorder);
   height: 1px;
@@ -100,6 +148,13 @@ body {
 .gs-preference-container {
   display: flex;
   justify-content: center;
+  flex: 0 0 auto;
+  position: sticky;
+  bottom: 0;
+  z-index: 1;
+  background: var(--theia-editor-background);
+  padding-top: 8px;
+  padding-bottom: 8px;
 }
 
 .gs-preference {
@@ -119,6 +174,18 @@ body {
   padding: 15px;
 }
 
+@media (max-width: 760px) {
+  .cybervinci-welcome-hero {
+    grid-template-columns: 1fr;
+    min-height: unset;
+  }
+
+  .cybervinci-welcome-art {
+    min-height: 220px;
+    background-position: center bottom;
+  }
+}
+
 .shadow-pulse {
   animation: shadowPulse 2s infinite ease-in-out;
 }

