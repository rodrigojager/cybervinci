    "test:flow-playbook-runner": "node scripts/check-flow-playbook-runner-smoke.js",
    "test:multi-agent-playbook": "node scripts/check-multi-agent-playbook-smoke.js",
    "test:native-agent-execution": "node scripts/check-native-agent-execution-smoke.js",
    "test:redaction": "node scripts/check-secret-redaction-smoke.js",
    "test:runtime-agents": "node scripts/check-runtime-agent-overlay-smoke.js",
    "test:runtime": "node scripts/check-playbook-runtime-smoke.js",
    "test:tools": "node scripts/check-tool-registry-smoke.js",
    "test:virtual-goal": "node scripts/check-virtual-goal-smoke.js",
    "test:ui-chat": "node scripts/check-ai-chat-ui-smoke.js",
    "test:ui-flow-playbook": "node scripts/check-ai-chat-ui-smoke.js --flow-playbook",
    "test:overlay-sync": "node scripts/check-overlay-sync.js",
    "test": "theiaext test",
    "watch": "theiaext watch"
