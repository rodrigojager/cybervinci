{
  "name": "@cybervinci/ai-chat-experience",
  "version": "1.72.0",
  "description": "CyberVinci AI Chat experience override for Theia",
  "dependencies": {
    "@cybervinci/ai-providers": "1.72.0",
    "@cybervinci/ai-runtime": "1.72.0",
    "@cybervinci/flow": "1.72.0",
    "@cybervinci/memory": "1.72.0",
    "@cybervinci/openpencil-extension": "1.72.0",
    "@theia/ai-chat": "1.72.0",
    "@theia/ai-core": "1.72.0",
    "@theia/ai-chat-ui": "1.72.0",
    "@theia/core": "1.72.0",
    "@theia/filesystem": "1.72.0",
    "@theia/workspace": "1.72.0",
    "js-yaml": "^4.1.1",
    "tslib": "^2.8.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/cybervinci-ai-chat-experience-frontend-module",
      "backend": "lib/node/cybervinci-ai-chat-experience-backend-module"
    }
  ],
  "keywords": [
