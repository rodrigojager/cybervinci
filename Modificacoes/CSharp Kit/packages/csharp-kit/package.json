{
  "name": "@cybervinci/csharp-kit",
  "version": "1.72.0",
  "description": "CyberVinci C#/.NET development kit for Theia",
  "license": "EPL-2.0 OR GPL-2.0-only WITH Classpath-exception-2.0",
  "main": "lib/common",
  "types": "lib/common/index.d.ts",
  "files": [
    "lib",
    "src",
    "scripts",
    "README.md"
  ],
  "dependencies": {
    "@cybervinci/branding": "1.72.0",
    "@cybervinci/memory": "1.72.0",
    "@cybervinci/memory-roslyn": "1.72.0",
    "@theia/ai-core": "1.72.0",
    "@theia/callhierarchy": "1.72.0",
    "@theia/core": "1.72.0",
    "@theia/debug": "1.72.0",
    "@theia/filesystem": "1.72.0",
    "@theia/markers": "1.72.0",
    "@theia/monaco": "1.72.0",
    "@theia/monaco-editor-core": "1.108.201",
    "@theia/navigator": "1.72.0",
    "@theia/task": "1.72.0",
    "@theia/test": "1.72.0",
    "@theia/terminal": "1.72.0",
    "@theia/typehierarchy": "1.72.0",
    "@theia/workspace": "1.72.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@theia/ext-scripts": "1.72.0"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/csharp-kit-frontend-module",
      "backend": "lib/node/csharp-kit-backend-module"
    }
  ],
  "keywords": [
    "theia-extension",
    "cybervinci",
    "csharp",
    "dotnet",
    "roslyn",
    "razor",
    "nuget"
  ],
  "scripts": {
    "build": "theiaext build",
    "clean": "theiaext clean",
    "compile": "theiaext compile",
    "lint": "theiaext lint",
    "test": "theiaext test",
    "check:runtime-readiness": "node ./scripts/runtime-readiness.js",
    "check:runtime-readiness:full": "node ./scripts/runtime-readiness.js --require-full --require-all-adapters --probe-language-servers",
    "test:csharp-ls-e2e": "node ./scripts/csharp-ls-e2e.js",
    "test:dotnet-workflow-e2e": "node ./scripts/dotnet-workflow-e2e.js",
    "watch": "theiaext watch"
  },
  "nyc": {
    "extends": "../../configs/nyc.json"
  }
}
